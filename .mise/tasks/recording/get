#!/usr/bin/env bash
#MISE description="Download the audio file for a specific recording"
#USAGE arg "<title>" help="Recording title (e.g., 'Feb 18 at 15:10')"
#USAGE flag "-o --output <output>" help="Output file path (default: suggested filename)"
set -eo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT="$SCRIPT_DIR/../../../scripts/get-recording.mjs"

ARGS=("${usage_title}")
if [ -n "${usage_output:-}" ]; then
  ARGS+=("${usage_output}")
fi

OUTPUT=$(shimmer browser:run "$SCRIPT" -- "${ARGS[@]}" 2>/dev/null | grep '^{')

if [ -z "$OUTPUT" ]; then
  echo "Failed to download recording." >&2
  exit 1
fi

FILE=$(echo "$OUTPUT" | jq -r '.file')
echo "Saved: $FILE"
