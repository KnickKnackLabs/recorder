#!/usr/bin/env bash
#MISE description="Download audio files for one or more recordings"
#USAGE arg "<title>" help="Recording title(s)" var=#true
#USAGE flag "-o --output-dir <output_dir>" help="Output directory (default: current directory)"
set -eo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT="$SCRIPT_DIR/../../scripts/download-recordings.mjs"

eval "TITLES=($usage_title)"

OUTPUT_DIR="$(cd "${usage_output_dir:-.}" && pwd)"

ARGS=("--output-dir=${OUTPUT_DIR}")
for title in "${TITLES[@]}"; do
  ARGS+=("$title")
done

OUTPUT=$(shimmer browser:run "$SCRIPT" -- "${ARGS[@]}" 2>/dev/null | grep '^\[')

if [ -z "$OUTPUT" ]; then
  echo "Failed to download recordings." >&2
  exit 1
fi

echo "$OUTPUT" | jq -r '.[] | if .error then "Error: \(.title) — \(.error)" else "Saved: \(.file)" end'
