#!/usr/bin/env bash
#MISE description="Browse recordings interactively"
set -eo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export RECORDER_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
SCRIPTS="$RECORDER_ROOT/scripts"

# Ensure cache directory exists
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/recorder"
mkdir -p "$CACHE_DIR/transcripts" "$CACHE_DIR/audio"

# Clean up playback on exit
cleanup() {
  local pidfile="$CACHE_DIR/.playback_pid"
  if [ -f "$pidfile" ]; then
    local pid
    pid=$(head -1 "$pidfile")
    kill "$pid" 2>/dev/null || true
    rm -f "$pidfile"
  fi
}
trap cleanup EXIT

HEADER=$("$SCRIPTS/browse-status.sh")

# Launch fzf
"$SCRIPTS/browse-list.sh" | fzf \
  --delimiter=$'\t' \
  --with-nth='1..' \
  --preview="$SCRIPTS/browse-preview.sh {1}" \
  --preview-window='right,60%,wrap,border-left' \
  --preview-label=' Details ' \
  --header="$HEADER" \
  --bind="ctrl-t:execute-silent($SCRIPTS/browse-fetch-transcript.sh {1})+refresh-preview" \
  --bind="ctrl-p:execute-silent($SCRIPTS/browse-play.sh {1})+refresh-preview+transform-header($SCRIPTS/browse-status.sh)" \
  --bind="ctrl-s:execute-silent($SCRIPTS/browse-stop.sh)+refresh-preview+transform-header($SCRIPTS/browse-status.sh)" \
  --bind="ctrl-d:execute($SCRIPTS/browse-download.sh {1})+refresh-preview" \
  --bind="ctrl-r:reload($SCRIPTS/browse-list.sh --refresh)" \
  --border=rounded \
  --border-label=' Recorder ' \
  --no-sort \
  --ansi \
  --layout=reverse
